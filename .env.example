# Sandman OSINT — API Keys
# Copy to .env and fill in your keys. All keys are optional; sources without keys are skipped.

# HaveIBeenPwned v3 — https://haveibeenpwned.com/API/Key
SANDMAN_HIBP_KEY=

# Hunter.io — https://hunter.io/api-keys
SANDMAN_HUNTER_KEY=

# Shodan — https://account.shodan.io/
SANDMAN_SHODAN_KEY=

# GitHub Personal Access Token (optional — increases rate limit)
SANDMAN_GITHUB_TOKEN=

# AI Analysis — configure one or both; use SANDMAN_AI_PROVIDER to force a choice
# Provider: "auto" (default) | "claude" | "gemini"
SANDMAN_AI_PROVIDER=auto

# Anthropic Claude API — https://console.anthropic.com/
SANDMAN_CLAUDE_KEY=
SANDMAN_CLAUDE_MODEL=claude-opus-4-6

# Google Gemini API — https://aistudio.google.com/app/apikey
SANDMAN_GEMINI_KEY=
SANDMAN_GEMINI_MODEL=gemini-2.0-flash

# Tor SOCKS5 proxy (requires Tor to be running)
SANDMAN_TOR=0
SANDMAN_TOR_ADDR=127.0.0.1:9050

# Server listen port
PORT=8080
